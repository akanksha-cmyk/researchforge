# Copy to .env — no trailing spaces

BRIGHTDATA_API_KEY=
BRIGHTDATA_ZONE=scraping_browser1
BRIGHTDATA_CUSTOMER_ID=
BRIGHTDATA_ZONE_PASSWORD=

DAYTONA_API_KEY=              # starts with dtn_
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=us

KIMI_API_KEY=                 # from platform.moonshot.ai — kimi-k2.6 + prefix caching
TOKENROUTER_API_KEY=          # from tokenrouter.io

NOSANA_API_KEY=               # nos_xxx from dashboard.nosana.com
NOSANA_API_URL=https://dashboard.k8s.prd.nos.ci/api
NOSANA_EMBED_URL=             # optional GPU embedding endpoint

SENSENOVA_API_KEY=            # sk-… from platform.sensenova.cn/token-plan
VIDEODB_API_KEY=
VIDEODB_VIDEO_URL=            # optional YouTube/video URL for live perception indexing

T3N_API_KEY=                  # Terminal 3 Agent Dev Kit sandbox key
TERMINAL3_API_KEY=            # alias for T3N_API_KEY
T3N_API_URL=https://api.terminal3.io
